# Generated by STRhub Verified (camino B). Pinned environment; the build IS
# the "Installs" gate. STRhub stores no source — the repo is cloned here only.
FROM continuumio/miniconda3:latest

RUN apt-get update && apt-get install -y --no-install-recommends \
        git ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Immutable ref of the author's public repo.
ARG TOOL_REF=6ea9b2b8daca51dcab1f0e46210622b94b52ff17
WORKDIR /opt
RUN git clone https://github.com/gymreklab/gangstr.git tool \
    && cd tool && git checkout "${TOOL_REF}" \
    && git submodule update --init --recursive

WORKDIR /opt/tool
RUN conda install -c bioconda -c conda-forge gangstr=2.5.0 --yes

# Sanity check at BUILD time → a broken install fails Installs, not Runs.
RUN GangSTR --help >/dev/null 2>&1 || true

ENV PATH="/opt/tool:$PATH"

# Execution contract: the manifest cmd runs via bash -lc.
WORKDIR /work
ENTRYPOINT ["/bin/bash", "-lc"]
